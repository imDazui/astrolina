{
  "name": "astrolina-maps",
  "private": true,
  "version": "1.0.0",
  "description": "A modern, web-based astrocartography tool for curious minds.",
  "homepage": "https://astrolina.org",
  "author": "AstroLina",
  "repository": {
    "type": "git",
    "url": "git+https://git.astrolina.org"
  },
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:eclipses": "tsx scripts/verify-eclipses.ts",
    "build:eclipses": "node scripts/build-eclipses.mjs",
    "deploy": "npm run build && wrangler pages deploy dist --project-name astrolina-maps",
    "deploy:preview": "npm run build && wrangler pages deploy dist --project-name astrolina-maps --branch preview"
  },
  "dependencies": {
    "@swisseph/browser": "1.1.0",
    "@turf/turf": "^7.3.5",
    "@types/luxon": "^3.7.1",
