    "kdbush": "^4.1.0",
    "luxon": "^3.7.2",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "topojson-client": "^3.1.0",
    "tz-lookup": "^6.1.25",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swisseph/node": "^1.2.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.3"
  },
  "comments": {
    "@swisseph/browser": "Pinned to 1.1.0 EXACTLY — do not upgrade to 1.1.1. The published 1.1.1 bundle is broken (enum references compile to `(void 0)`, so calculatePosition/calculateHouses throw). The overrides block enforces this against the broken `latest`."
  },
  "overrides": {
    "@swisseph/browser": "1.1.0"
  }
}
